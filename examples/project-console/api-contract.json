{
  "format": "api-contract.package.v1",
  "packageName": "project-console",
  "catalogs": [
    {
      "format": "api-contract.catalog.v1",
      "contractId": "project-console.interface",
      "title": "Project Console Interface Surface",
      "features": [
        {
          "id": "operation.project.report",
          "title": "Project report operation",
          "releaseTag": "public",
          "stability": "stable",
          "lifecycle": "active",
          "group": "operations"
        },
        {
          "id": "projection.cli.report",
          "title": "Report CLI projection",
          "releaseTag": "public",
          "stability": "stable",
          "lifecycle": "active",
          "group": "projections"
        },
        {
          "id": "projection.dashboard.report",
          "title": "Report dashboard projection",
          "releaseTag": "beta",
          "stability": "preview",
          "lifecycle": "active",
          "group": "projections"
        },
        {
          "id": "schema.project.config",
          "title": "Project config schema",
          "releaseTag": "public",
          "stability": "stable",
          "lifecycle": "active",
          "group": "schemas"
        }
      ]
    }
  ],
  "supported": [
    {
      "format": "api-contract.surface.v1",
      "contractId": "project-console.interface",
      "features": [
        "operation.project.report",
        "projection.cli.report",
        "projection.dashboard.report",
        "schema.project.config"
      ]
    }
  ],
  "x-interface": {
    "format": "api-contract.interface.v1",
    "operations": [
      {
        "id": "project.report",
        "title": "Project report",
        "description": "Create a local project status report from configured inputs.",
        "lifecycle": "active",
        "releaseTag": "public",
        "input": {
          "id": "project.report.input",
          "jsonSchema": {
            "type": "object",
            "required": ["projectName"],
            "properties": {
              "projectName": {
                "type": "string",
                "description": "Project name to show in the report."
              }
            }
          }
        },
        "output": {
          "id": "project.report.output",
          "jsonSchema": {
            "type": "object",
            "required": ["summary"],
            "properties": {
              "summary": {
                "type": "string"
              }
            }
          }
        },
        "effects": ["filesystem.read"],
        "receipts": [
          {
            "kind": "report",
            "description": "Local report written by the handler."
          }
        ],
        "docs": {
          "summary": "Reports are generated by the programmatic handler; CLI and dashboard surfaces only invoke it."
        },
        "featureId": "operation.project.report",
        "cli": {
          "command": "report",
          "interactive": false
        },
        "dashboard": {
          "group": "Project",
          "view": "form",
          "resultView": "summary",
          "transport": "machine-cli"
        }
      }
    ],
    "schemas": [
      {
        "id": "project.config",
        "title": "Project config",
        "description": "Configuration metadata used by generated forms and prompts.",
        "schema": {
          "type": "object",
          "required": ["projectName"],
          "properties": {
            "projectName": {
              "type": "string"
            }
          }
        },
        "featureId": "schema.project.config"
      }
    ],
    "docs": [],
    "projections": {
      "cli": [
        {
          "operationId": "project.report",
          "command": "report",
          "description": "Create a project report.",
          "outputMode": "json",
          "machine": {
            "describe": "project-console api describe project.report --json",
            "invoke": "project-console api invoke project.report --input-json <json>"
          }
        }
      ],
      "dashboard": [
        {
          "operationId": "project.report",
          "group": "Project",
          "view": "form",
          "resultView": "summary",
          "transport": "machine-cli",
          "description": "Render a local report form that invokes the machine JSON CLI."
        }
      ]
    }
  }
}
